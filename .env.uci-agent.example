UCI_AGENT_ENABLED=true
UCI_SCAN_INTERVAL_MINUTES=360
UCI_MAX_DAYS_AHEAD=120
UCI_MIN_AMOUNT_USD=5000
UCI_MAX_AMOUNT_USD=5000000
UCI_COP_TO_USD_RATE=4000
UCI_EUR_TO_USD_RATE=1.08
UCI_MAX_LINKS_PER_SOURCE=8
UCI_MAX_SOURCES_PER_CYCLE=20
UCI_ALWAYS_INCLUDE_COLOMBIA=true
UCI_SOURCE_IDS=
UCI_HTTP_TIMEOUT_MS=20000
UCI_USE_SEARCH_ENGINE=true
UCI_SEARCH_QUERIES_PER_SOURCE=2
UCI_PUBLIC_OPPORTUNITY_FILE=public/uci-opportunity.json
UCI_PUBLIC_OPPORTUNITY_HISTORY_FILE=public/uci-opportunity-history.json
UCI_NOTIFY_EMAIL=info@fundeter.org
UCI_MAIL_TRANSPORT=console
UCI_LOG_LEVEL=info

# SMTP mode
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Resend mode
RESEND_API_KEY=
RESEND_FROM=
